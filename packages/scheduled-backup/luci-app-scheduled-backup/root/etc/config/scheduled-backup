config scheduled_backup 'main'
	option enabled '0'
	option schedule_mode 'daily'
	option hour '3'
	option minute '0'
	option weekday '0'
	option local_enabled '0'
	option local_path '/mnt/backups'
	option local_keep '7'
	option sftp_enabled '0'
	option sftp_port '22'
	option sftp_auth 'password'
	option sftp_keep '7'
	option connect_timeout '15'
	option transfer_timeout '300'
