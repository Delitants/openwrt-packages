{
	"luci-app-netwatch": {
		"description": "Grant access to the Netwatch service",
		"read": {
			"uci": [ "netwatch" ],
			"ubus": {
				"luci-rpc": [ "getDHCPLeases" ],
				"netwatch": [ "status", "interfaces" ]
			}
		},
		"write": {
			"uci": [ "netwatch" ],
			"ubus": {
				"netwatch": [ "check", "test_email" ]
			}
		}
	}
}
